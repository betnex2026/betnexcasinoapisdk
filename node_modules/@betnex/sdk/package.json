{
  "name": "@betnex/sdk",
  "version": "1.0.2",
  "description": "Official JavaScript SDK for the Betnex Casino API",
  "type": "module",
  "main": "./dist/sdk.js",
  "exports": {
    ".": "./dist/sdk.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --format=cjs --minify --outfile=dist/sdk.js",
    "test": "node examples/testsdk.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "betnex",
    "casino",
    "casino-api",
    "gaming",
    "slots",
    "live-casino",
    "sportsbook",
    "turnkeyxgaming",
    "aggregation"
  ],
  "author": "Betnex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betnex2026/betnexcasinoapisdk.git"
  },
  "homepage": "https://casinoapi.betnex.co",
  "bugs": {
    "url": "https://github.com/betnex2026/betnexcasinoapisdk/issues"
  },
  "dependencies": {
    "@betnex/sdk": "^1.0.1",
    "axios": "^1.12.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
