{
  "name": "@betnex/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript SDK for the Betnex Casino API",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node examples/basic.js",
    "dev": "node --watch examples/basic.js",
    "test": "node examples/basic.js",
    "prepublishOnly": "npm test",
    "publish:npm": "npm publish --access public"
  },
  "keywords": [
    "betnex",
    "casino",
