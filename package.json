    "gaming",
    "slots",
    "live-casino",
    "sportsbook",
    "turnkeyxgaming",
    "aggregation"
  ],
  "author": "Betnex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betnex2026/betnexcasinoapisdk.git"
  },
  "homepage": "https://casinoapi.betnex.co",
  "bugs": {
    "url": "https://github.com/betnex2026/betnexcasinoapisdk/issues"
  },
  "dependencies": {
    "axios": "^1.12.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
