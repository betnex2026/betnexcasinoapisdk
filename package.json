{
  "name": "@betnex/sdk",
  "version": "1.0.3",
  "description": "Official JavaScript SDK for the Betnex Casino API",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "test": "node examples/testsdk.js",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node examples/testsdk.js",
    "publish:npm": "npm publish --access public",
    "build": "rollup -c"
  },
  "keywords": [
    "betnex",
    "casino",
    "casino-api",
    "gaming",
    "slots",
    "live-casino",
    "sportsbook",
    "turnkeyxgaming",
    "aggregation"
  ],
  "author": "Betnex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betnex2026/betnexcasinoapisdk.git"
  },
  "homepage": "https://casinoapi.betnex.co",
  "bugs": {
    "url": "https://github.com/betnex2026/betnexcasinoapisdk/issues"
  },
  "dependencies": {
    "axios": "^1.12.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.62.2"
  }
}
